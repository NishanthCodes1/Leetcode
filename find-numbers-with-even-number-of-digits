class Solution {
    public int findNumbers(int[] a) {
        int count=0;
        for(int i=0;i<a.length;i++){
            int ab=0;
            int b=a[i];
            while(b>0){
                b=b/10;
                ab+=1;
            }
            if(ab%2==0){
                count=count+1;
            }
        }
      return count;  
    }
}
